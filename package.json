{
  "name": "mp-auto-publisher",
  "version": "1.0.0",
  "description": "微信公众号全自动发文 H5 后台",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "stop": "pkill -f 'node .*server.js' 2>/dev/null; lsof -ti :${PORT:-3030} | xargs kill -9 2>/dev/null; true",
    "restart": "npm run stop --silent && sleep 1 && node --watch server.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "node-cron": "^3.0.3",
    "form-data": "^4.0.1"
  }
}
